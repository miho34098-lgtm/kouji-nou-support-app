# CC-03: 秘密情報は環境変数管理。本ファイルをコピーして .env を作成する（.envはgitignore対象）

# H1: DRY_RUN — デフォルトtrue。本番デプロイ時のみ明示的にfalseへ
VITE_DRY_RUN=true

# Firebase設定（Sparkプラン固定、ADR-005 — Blazeへのアップグレード禁止）
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Web Push VAPID公開鍵（クライアント側の購読に使用）
VITE_VAPID_PUBLIC_KEY=
